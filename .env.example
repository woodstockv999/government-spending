# Copy to .env.local and fill in. .env.local is git-ignored.

# e-Stat application ID (https://www.e-stat.go.jp/api/). Optional for the
# seed-CSV-only build; required once e-Stat fetching is wired in.
ESTAT_APP_ID=

# Random long secret protecting POST /api/admin/refresh.
# Generate e.g.: openssl rand -hex 32
ADMIN_TOKEN=

# Port PM2/Next listens on. Must not collide with briefing-bot (3000).
PORT=3001
